<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.whalebot.updater</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd ~/Documents/whalebot &amp;&amp; git pull origin main --ff-only &amp;&amp; launchctl kickstart -k gui/$(id -u)/com.whalebot.monitor</string>
    </array>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/tmp/whalebot-updater.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/whalebot-updater.stderr.log</string>
</dict>
</plist>
